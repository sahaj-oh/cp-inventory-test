# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# ---- Required ----

DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/openhouse-cp-portal?sslmode=require
JWT_SECRET=change-me-to-a-48-char-random-string

# ---- Properties DB (read-only queries for duplicate check + inventory) ----
PROPERTIES_DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/properties?sslmode=require

# ---- CORS ----
# In prod set to the SPA origin, e.g. https://cp-inventory-portal.vercel.app
# Used both for CORS and the CSRF Origin/Referer check on cookie-auth requests.
FRONTEND_ORIGIN=http://localhost:5173

# Flask environment: development or production
FLASK_ENV=development

# ---- Auth session cookie (HttpOnly) ----
# Session JWT rides in an HttpOnly cookie. SPA reaches the API same-origin
# (Vercel rewrite in prod, Vite proxy in dev) so the cookie is first-party and
# SameSite=Lax is enough. Defaults below are usually fine; override only if
# you change the cookie name or run a non-standard topology.
# AUTH_COOKIE_NAME=oh_token
# AUTH_COOKIE_SECURE=true        # auto: false in dev (http), true otherwise
# AUTH_COOKIE_SAMESITE=Lax
# AUTH_COOKIE_DOMAIN=            # blank = host-only (recommended)

# ---- Email alerts (Gmail SMTP) ----
# The sender address (use a Workspace account for production)
GMAIL_FROM_ADDRESS=support@openhouse.in
# 16-character app password from https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Set to "false" to temporarily silence alerts without changing code
ALERTS_ENABLED=true

# ---- Partner relay (server-to-server bypass) ----
# Shared API key sent by the partner relay as the X-API-Key header.
# Leave unset to disable relay auth entirely (all callers must use JWT).
# Generate a long random string (>= 48 chars) for production.
# RELAY_API_KEY=change-me-to-a-48-char-random-string
# RELAY_API_KEY_HEADER=X-API-Key  # default; only set if partner uses a different header name

# ---- OTP (Kaleyra SMS) ----
# Master switch. When false, /auth/send-otp / /auth/verify-otp bypass SMS
# and login falls back to phone-only.
OTP_ENABLED=false
# KALEYRA_API_KEY=
# KALEYRA_SID=HXIN1815766768IN
# KALEYRA_SENDER_ID=OHAVAN
# KALEYRA_TEMPLATE_ID=1107173502114302174
# Comma-separated 10-digit numbers that accept "000000" as a universal OTP.
# Empty by default. Only set this in local/dev — never in production.
# OTP_DEV_BYPASS_PHONES=
# OTP_EXPIRY_MINUTES=5
# OTP_MAX_ATTEMPTS=5
# OTP_SEND_RATE_LIMIT=3

# ---- Sync endpoints (Apps Script / Cloud Function callers) ----
# Shared secret sent as `X-Sync-Token` header on /api/sync/* endpoints.
# Generate a long random string (>= 48 chars). If unset, sync endpoints 503.
SYNC_SECRET_TOKEN=change-me-to-a-48-char-random-string

# ---- Forms App integration (Schedule Visit) ----
# External Forms app handles visit scheduling end-to-end. Admin clicks
# "Schedule Visit" → CP backend POSTs to FORMS_APP_URL/api/external/schedule
# with INTERNAL_API_KEY as the auth header. Forms app returns a UID
# we store on the submission.
# FORMS_APP_URL=https://forms.openhouse.in
# INTERNAL_API_KEY=change-me-to-a-shared-secret
# FORMS_APP_TIMEOUT_SECONDS=10

# ---- Cloudinary media upload (POST /api/media/upload) ----
# Uploads are proxied through the backend so the unsigned preset name isn't
# shipped to the browser. Unsigned upload needs only these two — no api_secret.
# The preset must be created as "unsigned" in the Cloudinary dashboard and
# allow the resource types you upload (image + video). Either unset = 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# CometChat (in-app chat)
COMET_APP_ID=
COMET_REGION=
COMET_REST_API_KEY=
COMET_AUTH_KEY=
COMET_WEBHOOK_USER=
COMET_WEBHOOK_PASS=
COMET_STAFF_UID=openhouse
